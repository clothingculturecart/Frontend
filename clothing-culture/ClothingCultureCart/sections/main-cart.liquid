<section class="cart">
  <h1>Your Cart</h1>

  {% if cart.item_count == 0 %}
    <p>Your cart is empty.</p>
    <a href="{{ routes.all_products_collection_url }}">Continue shopping</a>
  {% else %}
    {% form 'cart', cart %}
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">
            <div class="cart-item__info">
              <h3>{{ item.product.title }}</h3>
              <p>{{ item.variant.title }}</p>
              <p>{{ item.price | money }}</p>
            </div>
            <input type="number" name="updates[{{ forloop.index0 }}]" value="{{ item.quantity }}" min="0">
          </div>
        {% endfor %}
      </div>

      <div class="cart-total">
        <p>Subtotal: {{ cart.total_price | money }}</p>
        <button type="submit" name="checkout">Checkout</button>
      </div>
    {% endform %}
  {% endif %}
</section>

{% schema %}
{ "name": "Main Cart", "settings": [] }
{% endschema %}