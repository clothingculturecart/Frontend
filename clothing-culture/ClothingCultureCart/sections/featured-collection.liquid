<section class="featured-collection" data-swipe-gallery tabindex="0">
  <h2>{{ section.settings.heading }}</h2>

  {% assign products = collections[section.settings.collection].products %}

  <div class="swipe-stage" data-swipe-stage
        <div class="swipe-stage" data-swipe-stage
     style="background-image: url('{{ products.first.featured_image | image_url: width: 1200 }}');">
  <a href="{{ products.first.url }}" class="swipe-stage__link" data-swipe-link>View Product</a>
</div>

  <div class="swipe-thumbs">
    {% for product in products limit: 4 %}
      <button type="button"
              class="swipe-thumb{% if forloop.first %} is-active{% endif %}"
              data-swipe-thumb
              data-bg="{{ product.featured_image | image_url: width: 1200 }}"
              data-url="{{ product.url }}">
        <img src="{{ product.featured_image | image_url: width: 300 }}"
             width="300" height="375" alt="{{ product.title }}">
      </button>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "New Drops" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}